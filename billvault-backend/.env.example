# =============================================
# BillVault Backend -- Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=billvault
DB_USER=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (AES-256 for OAuth token storage at rest)
ENCRYPTION_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=553d257394d6c56ed0106cd0d0664723
R2_ACCESS_KEY_ID=20caa0d09cf517ee6a2f72a51fa999a3
R2_SECRET_ACCESS_KEY=b7b20b460511b45421cec0dda661c97066cefead0fa1e51b46e69b55d724487f
R2_BUCKET_NAME=billvault-storage
R2_ENDPOINT=https://553d257394d6c56ed0106cd0d0664723.r2.cloudflarestorage.com
R2_PUBLIC_URL=

# Google (Vision OCR + OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/email/gmail/callback
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase (FCM)
FIREBASE_SERVICE_ACCOUNT_PATH=

# SMTP (Transactional Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@billvault.app

# Frontend URL (for CORS + invite links)
FRONTEND_URL=http://localhost:3001

# Admin seed
ADMIN_EMAIL=